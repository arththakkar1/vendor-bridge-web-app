generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OFFICER
  MANAGER
  VENDOR
}

model User {
  id                String    @id @default(cuid())
  fullName          String
  email             String    @unique

  passwordHash      String
  role              UserRole

  resetToken        String?
  resetTokenExpiry  DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}